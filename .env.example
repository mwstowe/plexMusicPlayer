# Plex configuration
PLEX_URL=https://YOUR-IP-DASHES.YOUR-CERT-UUID.plex.direct:32400
PLEX_TOKEN=your_plex_token

# Music library name (as it appears in Plex)
PLEX_MUSIC_LIBRARY=Music

# CloudFront distribution domain for audio streaming
STREAM_BASE_URL=https://your-distribution-id.cloudfront.net

# DynamoDB table for queue persistence (auto-created by SAM)
QUEUE_TABLE=plexMusicPlayer-queue
